generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum deal_status {
  created
  awaiting_deposit
  pending_confirmation
  confirmed
  shipped
  completed
  disputed
  cancelled
}

enum payment_status {
  unpaid
  deposit_paid
  fully_paid
}

model Profile {
  id                        String   @id @db.Uuid
  name                      String   @default("")
  completed_deals_as_seller Int      @default(0)
  avg_rating_as_seller      Decimal  @default(0.00) @db.Decimal(3, 2)
  is_admin                  Boolean  @default(false)
  created_at                DateTime @default(now()) @db.Timestamptz(6)

  deals_as_seller  Deal[]   @relation("SellerDeals")
  deals_as_buyer   Deal[]   @relation("BuyerDeals")
  reviews_given    Review[] @relation("ReviewerReviews")
  reviews_received Review[] @relation("RevieweeReviews")

  @@map("profiles")
}

model Deal {
  id                    String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  seller_id             String         @db.Uuid
  buyer_id              String?        @db.Uuid
  title                 String
  description           String?
  total_amount          Decimal        @db.Decimal(12, 2)
  deposit_percent       Int            @default(30)
  deposit_amount        Decimal        @db.Decimal(12, 2)
  remaining_amount      Decimal        @db.Decimal(12, 2)
  fee_amount            Decimal        @db.Decimal(12, 2)
  payment_status        payment_status @default(unpaid)
  status                deal_status    @default(created)
  seller_bank_name      String
  seller_account_number String
  seller_account_name   String
  tracking_info         String?
  created_at            DateTime       @default(now()) @db.Timestamptz(6)
  updated_at            DateTime       @default(now()) @db.Timestamptz(6)

  seller  Profile   @relation("SellerDeals", fields: [seller_id], references: [id])
  buyer   Profile?  @relation("BuyerDeals", fields: [buyer_id], references: [id])
  dispute Dispute?
  review  Review?

  @@map("deals")
}

model Dispute {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deal_id      String    @unique @db.Uuid
  reason       String
  evidence_url String?
  verdict      String?
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  resolved_at  DateTime? @db.Timestamptz(6)

  deal Deal @relation(fields: [deal_id], references: [id])

  @@map("disputes")
}

model Review {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deal_id     String   @unique @db.Uuid
  reviewer_id String   @db.Uuid
  reviewee_id String   @db.Uuid
  rating      Int
  comment     String?
  created_at  DateTime @default(now()) @db.Timestamptz(6)

  deal     Deal    @relation(fields: [deal_id], references: [id])
  reviewer Profile @relation("ReviewerReviews", fields: [reviewer_id], references: [id])
  reviewee Profile @relation("RevieweeReviews", fields: [reviewee_id], references: [id])

  @@map("reviews")
}
